[application]

config/name="Sun City Open World"
config/description="Bright GTA-inspired 2D open world city game"
run/main_scene="res://Scenes/Main/Bootstrap.tscn"
config/icon="res://icon.svg"

[autoload]

GameEvents="*res://Scripts/Core/GameEvents.gd"
GameManager="*res://Scripts/Managers/GameManager.gd"
SceneManager="*res://Scripts/Managers/SceneManager.gd"
SaveManager="*res://Scripts/Managers/SaveManager.gd"

[display]

window/size/height=576
window/stretch/mode="2d"
window/stretch/aspect="keep"
window/stretch/shrink=1

